{
  "name": "@zhixuan92/multi-model-agent-core",
  "version": "5.6.2",
  "type": "module",
  "license": "MIT",
  "description": "Core library for multi-model-agent: provider runners (Claude, Codex), routing logic, config schema, and sandbox primitives.",
  "author": "Zhang Zhixuan <zhangzhixuan312@gmail.com>",
  "keywords": [
    "mcp",
    "llm",
